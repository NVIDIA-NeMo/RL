#!/usr/bin/env bash
# Auto-generated by tools/generate_eagle_tar_drift_slurm_submits.py
#SBATCH --job-name=eagle-tardrift-s123
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=224
#SBATCH --time=04:00:00
#SBATCH --output=/home/scratch.shaunakj_other/logs/slurm-%x-%j.out
#SBATCH --error=/home/scratch.shaunakj_other/logs/slurm-%x-%j.err
#SBATCH --partition=b200@cr+mp-1000W/umbriel-b200@ts4/8gpu-224cpu-2048gb
#SBATCH --gpus-per-node=8

set -euo pipefail

MODE="${1:-both}"  # train | frozen | both
case "$MODE" in
  train|frozen|both) ;;
  *)
    echo "Usage: $0 [train|frozen|both]"
    exit 2
    ;;
esac

REPO_ROOT="/home/scratch.shaunakj_other/Development/RL"
SCR="/home/scratch.shaunakj_other"
SEED="123"

RUN_STEPS="${RUN_STEPS:-135}"
ARM_TIMEOUT="${ARM_TIMEOUT:-230m}"
SPEC_TOKENS="${SPEC_TOKENS:-4}"
TRAIN_LR="${TRAIN_LR:-5e-06}"
FROZEN_LR="${FROZEN_LR:-0.0}"
MAX_EPOCHS="${MAX_EPOCHS:-1}"
PROMPTS_PER_STEP="${PROMPTS_PER_STEP:-2}"
GENERATIONS_PER_PROMPT="${GENERATIONS_PER_PROMPT:-4}"
GEN_TEMPERATURE="${GEN_TEMPERATURE:-0.6}"
RATIO_CLIP="${RATIO_CLIP:-0.2}"
REF_KL="${REF_KL:-0.01}"
MAX_GRAD_NORM="${MAX_GRAD_NORM:-1.0}"
CLUSTER_GPUS_PER_NODE="${CLUSTER_GPUS_PER_NODE:-${SLURM_GPUS_ON_NODE:-8}}"
SAVE_PERIOD="${SAVE_PERIOD:-50}"
CKPT_SIZE_GIB="${CKPT_SIZE_GIB:-368}"
SPACE_RESERVE_GIB="${SPACE_RESERVE_GIB:-300}"
CONCURRENT_TRAIN_JOBS="${CONCURRENT_TRAIN_JOBS:-5}"
CKPT_KEEP_TOP_K="${CKPT_KEEP_TOP_K:-6}"
RESUME_CHECKPOINT_DIR="${RESUME_CHECKPOINT_DIR:-}"

TARGET_MODEL="/home/scratch.shaunakj_other/.cache/huggingface/hub/models--Qwen--Qwen3-32B/snapshots/9216db5781bf21249d130ec9da846c4624c16137"
EAGLE_MODEL="/home/scratch.shaunakj_other/.cache/hf_user/hub/models--RedHatAI--Qwen3-32B-speculator.eagle3/snapshots/e5756763c9b3bef3cc260cab70b76008fb42a81b"
DATASET_PATH="/home/scratch.shaunakj_other/openmath-cached-sample-256.jsonl"
BASE_CFG="/home/scratch.shaunakj_other/Development/RL/examples/configs/recipes/llm/grpo-qwen3-32b-spec-decode-lowbatch-1n8g.yaml"

export HOME="$SCR"
export PATH="$REPO_ROOT/.venv/bin:$SCR/.local/bin:$PATH"
export VIRTUAL_ENV="$REPO_ROOT/.venv"

export TMPDIR="$SCR/t"
export TMP="$SCR/t"
export TEMP="$SCR/t"
export UV_CACHE_DIR="$SCR/.cache/uv"
export XDG_CACHE_HOME="$SCR/.cache"
export VLLM_CACHE_ROOT="$SCR/.cache/vllm"
export HF_HOME="$SCR/.cache/hf_user"
export HF_HUB_CACHE="$SCR/.cache/hf_user/hub"
export HUGGINGFACE_HUB_CACHE="$SCR/.cache/hf_user/hub"
export TRANSFORMERS_CACHE="$SCR/.cache/hf_user/hub"
export HF_DATASETS_CACHE="$SCR/.cache/hf_json_cache"

export RAY_TMPDIR="$SCR/t/ray"
export RAY_ENABLE_UV_RUN_RUNTIME_ENV="${RAY_ENABLE_UV_RUN_RUNTIME_ENV:-0}"
export VLLM_LOG_STATS_INTERVAL=1
export PYTHONUNBUFFERED=1
export NRL_FORCE_LOCAL_RAY=true
export NEMO_RL_PY_EXECUTABLES_SYSTEM="${NEMO_RL_PY_EXECUTABLES_SYSTEM:-1}"
export NRL_FORCE_REBUILD_VENVS="${NRL_FORCE_REBUILD_VENVS:-false}"
export VLLM_DISABLE_COMPILE_CACHE=1
export VENV_NAMESPACE="${VENV_NAMESPACE:-eagle-tardrift-seed${SEED}-job${SLURM_JOB_ID:-manual}}"
export NEMO_RL_VENV_DIR="${NEMO_RL_VENV_DIR:-$SCR/venvs/${VENV_NAMESPACE}}"
export POLICY_PY="${POLICY_PY:-$REPO_ROOT/.venv/bin/python}"
export PRECHECK_TIMEOUT_SECONDS="${PRECHECK_TIMEOUT_SECONDS:-180}"

# Best-effort CUDA toolkit discovery for any runtime env rebuild path that compiles extensions.
if [[ -z "${CUDA_HOME:-}" ]]; then
  if command -v nvcc >/dev/null 2>&1; then
    CUDA_HOME="$(dirname "$(dirname "$(readlink -f "$(command -v nvcc)")")")"
  elif [[ -d /usr/local/cuda ]]; then
    CUDA_HOME="/usr/local/cuda"
  elif compgen -G "/usr/local/cuda-*" >/dev/null; then
    CUDA_HOME="$(ls -d /usr/local/cuda-* | sort -V | tail -n 1)"
  fi
  if [[ -n "${CUDA_HOME:-}" ]]; then
    export CUDA_HOME
  fi
fi
if [[ -n "${CUDA_HOME:-}" ]]; then
  export PATH="$CUDA_HOME/bin:$PATH"
  export LD_LIBRARY_PATH="$CUDA_HOME/lib64:${LD_LIBRARY_PATH:-}"
fi

mkdir -p "$SCR/t" "$SCR/logs" "$SCR/results"   "$UV_CACHE_DIR" "$XDG_CACHE_HOME" "$VLLM_CACHE_ROOT" "$NEMO_RL_VENV_DIR"   "$HF_HUB_CACHE" "$HF_DATASETS_CACHE" "$RAY_TMPDIR"

# Clear stale build markers to avoid deadlock in nemo_rl.utils.venvs._env_builder.
if [[ -d "$NEMO_RL_VENV_DIR" ]]; then
  while IFS= read -r started_file; do
    venv_dir="$(dirname "$started_file")"
    if [[ ! -x "$venv_dir/bin/python" ]]; then
      echo "Removing stale STARTED_ENV_BUILDER marker: $started_file"
      rm -f "$started_file"
    fi
  done < <(find "$NEMO_RL_VENV_DIR" -maxdepth 2 -type f -name STARTED_ENV_BUILDER 2>/dev/null || true)
fi

resolve_python_bin() {
  local c=""
  local -a candidates=(
    "${POLICY_PY:-}"
    "$REPO_ROOT/.venv/bin/python"
    "$REPO_ROOT/.venv/bin/python3.12"
    "$REPO_ROOT/.venv/bin/python3"
    "/usr/bin/python3.12"
    "/bin/python3.12"
    "$(command -v python3.12 2>/dev/null || true)"
    "$(command -v python3 2>/dev/null || true)"
    "$(command -v python 2>/dev/null || true)"
  )
  for c in "${candidates[@]}"; do
    if [[ -n "$c" && -x "$c" ]]; then
      echo "$c"
      return 0
    fi
  done
  return 1
}

if [[ "$NEMO_RL_PY_EXECUTABLES_SYSTEM" == "1" ]]; then
  if [[ ! -x "$POLICY_PY" ]]; then
    if resolved_py="$(resolve_python_bin)"; then
      echo "WARN: POLICY_PY is not executable: $POLICY_PY; falling back to ${resolved_py}" | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
      POLICY_PY="$resolved_py"
      export POLICY_PY
    else
      echo "ERROR: POLICY_PY is not executable and no fallback python found: $POLICY_PY" | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
      exit 5
    fi
  fi
  if [[ "$POLICY_PY" != "$REPO_ROOT/.venv/bin/python" && -d "$REPO_ROOT/.venv/lib/python3.12/site-packages" ]]; then
    export PYTHONPATH="$REPO_ROOT/.venv/lib/python3.12/site-packages:${PYTHONPATH:-}"
  fi

  # A broken transformer-engine meta package in the policy env causes worker import stalls/failures.
  if ! "$POLICY_PY" - <<'PY' >/dev/null 2>&1
import importlib.util

if importlib.util.find_spec("transformer_engine") is None:
    raise SystemExit(0)
try:
    import transformer_engine.pytorch  # noqa: F401
except Exception:
    raise SystemExit(1)
raise SystemExit(0)
PY
  then
    echo "WARN: Broken transformer-engine detected in POLICY_PY env; uninstalling it for this run." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    "$POLICY_PY" -m pip uninstall -y transformer-engine transformer_engine >/dev/null 2>&1 || true
  fi

  set +e
  timeout "$PRECHECK_TIMEOUT_SECONDS" "$POLICY_PY" - <<'PY' >/dev/null 2>&1
import torch  # noqa: F401
import vllm  # noqa: F401
import vllm._C  # noqa: F401
try:
    # Older torch path
    from torch.distributed.tensor import register_op_strategy  # noqa: F401
except ImportError:
    # Newer torch path
    from torch.distributed.tensor._ops.utils import register_op_strategy  # noqa: F401
import nemo_automodel.components._peft.module_matcher  # noqa: F401
PY
  preflight_rc=$?
  set -e
  if [[ "$preflight_rc" -ne 0 ]]; then
    if [[ "$preflight_rc" -eq 124 ]]; then
      echo "ERROR: POLICY_PY preflight timed out after ${PRECHECK_TIMEOUT_SECONDS}s." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
      echo "Likely stuck importing nemo_automodel module_matcher / transformer-engine path." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    else
      echo "ERROR: POLICY_PY preflight import check failed (torch/vLLM/DTensor/module_matcher), likely env mismatch." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    fi
    if command -v nvcc >/dev/null 2>&1 || [[ -n "${CUDA_HOME:-}" ]]; then
      echo "Try re-submitting with:" | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
      echo "  --export=ALL,NEMO_RL_PY_EXECUTABLES_SYSTEM=0,RAY_ENABLE_UV_RUN_RUNTIME_ENV=1,NRL_FORCE_REBUILD_VENVS=true" | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    else
      echo "This node has no CUDA toolkit (nvcc/CUDA_HOME), so runtime venv rebuild will fail." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
      echo "Fix the frozen env on login node (install a torch-compatible vLLM wheel), then resubmit in system mode." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    fi
    exit 3
  fi
fi

if [[ "$NEMO_RL_PY_EXECUTABLES_SYSTEM" == "0" || "$NRL_FORCE_REBUILD_VENVS" == "true" ]]; then
  if ! command -v nvcc >/dev/null 2>&1 && [[ -z "${CUDA_HOME:-}" ]]; then
    echo "ERROR: runtime-env rebuild requested, but nvcc/CUDA_HOME is unavailable on this node." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    echo "This cluster shape cannot build deep-ep from source without CUDA toolkit." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    echo "Use a node image with CUDA toolkit, or switch back to frozen/system mode with a compatible .venv." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    exit 4
  fi
fi

LAUNCH_PY="${LAUNCH_PY:-$POLICY_PY}"
if [[ ! -x "$LAUNCH_PY" ]]; then
  if ! LAUNCH_PY="$(resolve_python_bin)"; then
    echo "ERROR: could not resolve a launch python interpreter." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
    exit 5
  fi
fi
export LAUNCH_PY

cd "$REPO_ROOT"

EXP_TS="$(date +%F-%H%M%S)"
EXP_ROOT="$SCR/logs/tar-drift-reasonable-seed${SEED}-s${SPEC_TOKENS}-steps${RUN_STEPS}-${EXP_TS}"
EXP_RESULTS_ROOT="$SCR/results/tar-drift-reasonable-seed${SEED}-s${SPEC_TOKENS}-steps${RUN_STEPS}-${EXP_TS}"
mkdir -p "$EXP_ROOT" "$EXP_RESULTS_ROOT"

LOCAL_CFG="$SCR/t/grpo-qwen3-32b-eagle3-lowbatch.${EXP_TS}.seed${SEED}.local.yaml"
cp "$BASE_CFG" "$LOCAL_CFG"
sed -i "s#^defaults: /opt/nemo-rl/examples/configs/grpo_math_1B.yaml#defaults: $REPO_ROOT/examples/configs/grpo_math_1B.yaml#" "$LOCAL_CFG"

STATUS="$EXP_ROOT/status.log"
{
  echo "$(date '+%F %T %Z') START mode=${MODE} seed=${SEED} steps=${RUN_STEPS} spec_tokens=${SPEC_TOKENS}"
  echo "$(date '+%F %T %Z') profile=reasonable train_lr=${TRAIN_LR} frozen_lr=${FROZEN_LR} max_epochs=${MAX_EPOCHS}"
  echo "$(date '+%F %T %Z') clip=${RATIO_CLIP} ref_kl=${REF_KL} max_grad_norm=${MAX_GRAD_NORM} temp=${GEN_TEMPERATURE}"
  echo "$(date '+%F %T %Z') dataset_path=${DATASET_PATH}"
  echo "exp_root=${EXP_ROOT}"
  echo "exp_results_root=${EXP_RESULTS_ROOT}"
  echo "local_cfg=${LOCAL_CFG}"
  echo "resume_checkpoint_dir=${RESUME_CHECKPOINT_DIR:-none}"
  echo "nemo_rl_venv_dir=${NEMO_RL_VENV_DIR}"
  echo "policy_py=${POLICY_PY}"
  echo "nemo_rl_py_executables_system=${NEMO_RL_PY_EXECUTABLES_SYSTEM} nrl_force_rebuild_venvs=${NRL_FORCE_REBUILD_VENVS}"
  echo "cuda_home=${CUDA_HOME:-unset}"
} | tee "$STATUS"

find_latest_step_dir() {
  local ckpt_dir="$1"
  local latest_step=-1
  local latest_dir=""
  local dir=""
  local name=""
  local step=""

  shopt -s nullglob
  for dir in "$ckpt_dir"/step_*; do
    name="$(basename "$dir")"
    if [[ "$name" =~ ^step_([0-9]+)$ ]]; then
      step="${BASH_REMATCH[1]}"
      if (( step > latest_step )); then
        latest_step="$step"
        latest_dir="$dir"
      fi
    fi
  done
  shopt -u nullglob

  if (( latest_step < 0 )); then
    return 1
  fi
  printf '%s\n' "$latest_dir"
}

run_arm() {
  local arm="$1"
  local lr="$2"
  local ckpt_enabled="true"
  local ckpt_save_period="$SAVE_PERIOD"
  local ckpt_keep_top_k="$CKPT_KEEP_TOP_K"
  local avail_gib=""
  local safe_ckpts_per_job=""
  if [[ "$arm" == "frozen" ]]; then
    ckpt_enabled="false"
  else
    avail_gib=$(df --output=avail -BG "$SCR" | tail -1 | tr -cd '0-9')
    local ckpt_size_gib="$CKPT_SIZE_GIB"
    local reserve_gib="$SPACE_RESERVE_GIB"
    local concurrent_jobs="$CONCURRENT_TRAIN_JOBS"

    if [[ ! "$avail_gib" =~ ^[0-9]+$ ]]; then
      avail_gib=0
    fi
    if [[ ! "$ckpt_size_gib" =~ ^[0-9]+$ || "$ckpt_size_gib" -le 0 ]]; then
      ckpt_size_gib=368
    fi
    if [[ ! "$reserve_gib" =~ ^[0-9]+$ || "$reserve_gib" -lt 0 ]]; then
      reserve_gib=300
    fi
    if [[ ! "$concurrent_jobs" =~ ^[0-9]+$ || "$concurrent_jobs" -le 0 ]]; then
      concurrent_jobs=1
    fi
    if [[ ! "$ckpt_save_period" =~ ^[0-9]+$ || "$ckpt_save_period" -le 0 ]]; then
      ckpt_save_period=50
    fi
    if [[ ! "$ckpt_keep_top_k" =~ ^[0-9]+$ || "$ckpt_keep_top_k" -le 0 ]]; then
      ckpt_keep_top_k=1
    fi

    local usable_gib=$((avail_gib - reserve_gib))
    if (( usable_gib < 0 )); then
      usable_gib=0
    fi

    local max_total_ckpts=$((usable_gib / ckpt_size_gib))
    safe_ckpts_per_job=$((max_total_ckpts / concurrent_jobs))
    if (( safe_ckpts_per_job < 1 )); then
      safe_ckpts_per_job=1
    fi

    local min_save_period=$(((RUN_STEPS + safe_ckpts_per_job - 1) / safe_ckpts_per_job))
    if (( min_save_period < 1 )); then
      min_save_period=1
    fi
    if (( ckpt_save_period < min_save_period )); then
      ckpt_save_period="$min_save_period"
    fi
    if (( ckpt_keep_top_k > safe_ckpts_per_job )); then
      ckpt_keep_top_k="$safe_ckpts_per_job"
    fi
  fi

  local run_tag="tar-drift-reasonable-eagle3-s${SPEC_TOKENS}-seed${SEED}-${arm}-steps${RUN_STEPS}-${EXP_TS}"
  local logroot="$SCR/logs/${run_tag}"
  local resroot="$SCR/results/${run_tag}"
  local run_log="$logroot/run-${RUN_STEPS}steps-seed${SEED}-${arm}-eagle3.log"
  local resume_step_dir=""
  local resume_step_name=""
  local skip_train_dataloader_resume="${NRL_SKIP_TRAIN_DATALOADER_RESUME:-}"

  if [[ "$arm" == "train" && -n "$RESUME_CHECKPOINT_DIR" ]]; then
    if [[ ! -d "$RESUME_CHECKPOINT_DIR" ]]; then
      echo "ERROR: RESUME_CHECKPOINT_DIR does not exist: $RESUME_CHECKPOINT_DIR" | tee -a "$STATUS"
      return 6
    fi
    if ! resume_step_dir="$(find_latest_step_dir "$RESUME_CHECKPOINT_DIR")"; then
      echo "ERROR: RESUME_CHECKPOINT_DIR has no step_* checkpoints: $RESUME_CHECKPOINT_DIR" | tee -a "$STATUS"
      return 6
    fi
    resume_step_name="$(basename "$resume_step_dir")"
    if [[ ! -d "$resume_step_dir/policy/weights" ]]; then
      echo "ERROR: Missing policy weights in ${resume_step_dir}/policy/weights" | tee -a "$STATUS"
      return 6
    fi
    if [[ ! -d "$resume_step_dir/policy/optimizer" ]]; then
      echo "ERROR: Missing policy optimizer state in ${resume_step_dir}/policy/optimizer" | tee -a "$STATUS"
      return 6
    fi
    resroot="$RESUME_CHECKPOINT_DIR"
    if [[ -z "$skip_train_dataloader_resume" ]]; then
      skip_train_dataloader_resume=1
    fi
  fi

  mkdir -p "$logroot"
  if [[ "$ckpt_enabled" == "true" ]]; then
    mkdir -p "$resroot"
  fi
  echo "$(date '+%F %T %Z') seed=${SEED} arm=${arm} lr=${lr} ckpt_enabled=${ckpt_enabled} ckpt_save_period=${ckpt_save_period} ckpt_keep_top_k=${ckpt_keep_top_k} safe_ckpts_per_job=${safe_ckpts_per_job:-n/a} avail_gib=${avail_gib:-n/a} logroot=${logroot} checkpoint_dir=${resroot} resume_step=${resume_step_name:-none} skip_train_dataloader_resume=${skip_train_dataloader_resume:-0}" | tee -a "$STATUS"

  .venv/bin/ray stop --force || true

  export NRL_SKIP_TRAIN_DATALOADER_RESUME="${skip_train_dataloader_resume:-}"
  timeout "$ARM_TIMEOUT" stdbuf -oL -eL "$LAUNCH_PY" -     --config "$LOCAL_CFG"     "++grpo.max_num_steps=${RUN_STEPS}"     "++grpo.max_num_epochs=${MAX_EPOCHS}"     "++grpo.val_period=0"     "++grpo.val_at_start=false"     "++grpo.val_at_end=false"     "++grpo.seed=${SEED}"     "++grpo.num_prompts_per_step=${PROMPTS_PER_STEP}"     "++grpo.num_generations_per_prompt=${GENERATIONS_PER_PROMPT}"     "++policy.dtensor_cfg.activation_checkpointing=true"     "++policy.model_name=${TARGET_MODEL}"     "++policy.tokenizer.name=${TARGET_MODEL}"     "++policy.max_total_sequence_length=5120"     "++policy.generation.max_new_tokens=4096"     "++policy.generation.temperature=${GEN_TEMPERATURE}"     "++policy.generation.top_p=1.0"     "++policy.generation.top_k=null"     "++policy.generation.vllm_cfg.load_format=auto"     "++policy.generation.vllm_cfg.max_model_len=5120"     "++policy.generation.vllm_kwargs.attention_backend=FLASH_ATTN"     "++policy.generation.vllm_kwargs.speculative_config.model=${EAGLE_MODEL}"     "++policy.generation.vllm_kwargs.speculative_config.method=eagle3"     "++policy.generation.vllm_kwargs.speculative_config.num_speculative_tokens=${SPEC_TOKENS}"     "++policy.generation.vllm_kwargs.speculative_config.draft_tensor_parallel_size=1"     "++policy.optimizer.kwargs.lr=${lr}"     "++policy.max_grad_norm=${MAX_GRAD_NORM}"     "++loss_fn.ratio_clip_min=${RATIO_CLIP}"     "++loss_fn.ratio_clip_max=${RATIO_CLIP}"     "++loss_fn.reference_policy_kl_penalty=${REF_KL}"     "++cluster.gpus_per_node=${CLUSTER_GPUS_PER_NODE}"     "++cluster.num_nodes=1"     "++env.math.num_workers=1"     "++data.train.dataset_name=ResponseDataset"     "++data.train.data_path=${DATASET_PATH}"     "++data.train.split_validation_size=0.0"     "++data.validation=null"     "++data.default.dataset_name=ResponseDataset"     "++data.default.input_key=input"     "++data.default.output_key=output"     "++data.default.processor=math_hf_data_processor"     "++data.default.env_name=math"     "++data.default.prompt_file=examples/prompts/cot.txt"     "++logger.log_dir=${logroot}"     "++checkpointing.enabled=${ckpt_enabled}"     "++checkpointing.save_period=${ckpt_save_period}"     "++checkpointing.keep_top_k=${ckpt_keep_top_k}"     "++checkpointing.checkpoint_dir=${resroot}"     <<'PY' 2>&1 | tee "$run_log"
import os
import runpy
import sys

from nemo_rl.distributed.ray_actor_environment_registry import ACTOR_ENVIRONMENT_REGISTRY

policy_py = os.environ.get("POLICY_PY")
if policy_py:
    ACTOR_ENVIRONMENT_REGISTRY[
        "nemo_rl.models.policy.workers.dtensor_policy_worker_v2.DTensorPolicyWorkerV2"
    ] = policy_py
    ACTOR_ENVIRONMENT_REGISTRY[
        "nemo_rl.models.policy.workers.dtensor_policy_worker.DTensorPolicyWorker"
    ] = policy_py

sys.argv = ["examples/run_grpo.py", *sys.argv[1:]]
runpy.run_path("examples/run_grpo.py", run_name="__main__")
PY

  local rc=${PIPESTATUS[0]}
  echo "$(date '+%F %T %Z') seed=${SEED} arm=${arm} rc=${rc} run_log=${run_log}" | tee -a "$STATUS"
  return "$rc"
}

case "$MODE" in
  train)
    run_arm train "$TRAIN_LR"
    ;;
  frozen)
    run_arm frozen "$FROZEN_LR"
    ;;
  both)
    run_arm train "$TRAIN_LR"
    run_arm frozen "$FROZEN_LR"
    ;;
esac

echo "$(date '+%F %T %Z') DONE mode=${MODE} seed=${SEED} exp_root=${EXP_ROOT}" | tee -a "$STATUS"
