  exit 3
fi

cd "$REPO_ROOT"

EXP_TS="$(date +%F-%H%M%S)"
EXP_ROOT="$SCR/logs/tar-drift-reasonable-seed${SEED}-s${SPEC_TOKENS}-steps${RUN_STEPS}-${EXP_TS}"
EXP_RESULTS_ROOT="$SCR/results/tar-drift-reasonable-seed${SEED}-s${SPEC_TOKENS}-steps${RUN_STEPS}-${EXP_TS}"
mkdir -p "$EXP_ROOT" "$EXP_RESULTS_ROOT"

LOCAL_CFG="$SCR/t/grpo-qwen3-32b-eagle3-lowbatch.${EXP_TS}.seed${SEED}.local.yaml"
cp "$BASE_CFG" "$LOCAL_CFG"
sed -i "s#^defaults: /opt/nemo-rl/examples/configs/grpo_math_1B.yaml#defaults: $REPO_ROOT/examples/configs/grpo_math_1B.yaml#" "$LOCAL_CFG"

STATUS="$EXP_ROOT/status.log"
{
  echo "$(date '+%F %T %Z') START mode=${MODE} seed=${SEED} steps=${RUN_STEPS} spec_tokens=${SPEC_TOKENS}"
  echo "$(date '+%F %T %Z') profile=reasonable train_lr=${TRAIN_LR} frozen_lr=${FROZEN_LR} max_epochs=${MAX_EPOCHS}"
  echo "$(date '+%F %T %Z') clip=${RATIO_CLIP} ref_kl=${REF_KL} max_grad_norm=${MAX_GRAD_NORM} temp=${TEMP}"
  echo "$(date '+%F %T %Z') dataset_path=${DATASET_PATH}"
  echo "exp_root=${EXP_ROOT}"
  echo "exp_results_root=${EXP_RESULTS_ROOT}"
  echo "local_cfg=${LOCAL_CFG}"
} | tee "$STATUS"

run_arm() {
  local arm="$1"
  local lr="$2"

  local run_tag="tar-drift-reasonable-eagle3-s${SPEC_TOKENS}-seed${SEED}-${arm}-steps${RUN_STEPS}-${EXP_TS}"
  local logroot="$SCR/logs/${run_tag}"
  local resroot="$SCR/results/${run_tag}"
  local run_log="$logroot/run-${RUN_STEPS}steps-seed${SEED}-${arm}-eagle3.log"

  mkdir -p "$logroot" "$resroot"
  echo "$(date '+%F %T %Z') seed=${SEED} arm=${arm} lr=${lr} logroot=${logroot}" | tee -a "$STATUS"

  .venv/bin/ray stop --force || true

  timeout "$ARM_TIMEOUT" stdbuf -oL -eL .venv/bin/python examples/run_grpo.py     --config "$LOCAL_CFG"     "++grpo.max_num_steps=${RUN_STEPS}"     "++grpo.max_num_epochs=${MAX_EPOCHS}"     "++grpo.val_period=0"     "++grpo.val_at_start=false"     "++grpo.val_at_end=false"     "++grpo.seed=${SEED}"     "++grpo.num_prompts_per_step=${PROMPTS_PER_STEP}"     "++grpo.num_generations_per_prompt=${GENERATIONS_PER_PROMPT}"     "++policy.dtensor_cfg.activation_checkpointing=true"     "++policy.model_name=${TARGET_MODEL}"     "++policy.tokenizer.name=${TARGET_MODEL}"     "++policy.max_total_sequence_length=5120"     "++policy.generation.max_new_tokens=4096"     "++policy.generation.temperature=${TEMP}"     "++policy.generation.top_p=1.0"     "++policy.generation.top_k=null"     "++policy.generation.vllm_cfg.load_format=auto"     "++policy.generation.vllm_cfg.max_model_len=5120"     "++policy.generation.vllm_kwargs.attention_backend=FLASH_ATTN"     "++policy.generation.vllm_kwargs.speculative_config.model=${EAGLE_MODEL}"     "++policy.generation.vllm_kwargs.speculative_config.method=eagle3"     "++policy.generation.vllm_kwargs.speculative_config.num_speculative_tokens=${SPEC_TOKENS}"     "++policy.generation.vllm_kwargs.speculative_config.draft_tensor_parallel_size=1"     "++policy.optimizer.kwargs.lr=${lr}"     "++policy.max_grad_norm=${MAX_GRAD_NORM}"     "++loss_fn.ratio_clip_min=${RATIO_CLIP}"     "++loss_fn.ratio_clip_max=${RATIO_CLIP}"     "++loss_fn.reference_policy_kl_penalty=${REF_KL}"     "++cluster.gpus_per_node=8"     "++cluster.num_nodes=1"     "++env.math.num_workers=1"     "++data.train.dataset_name=ResponseDataset"     "++data.train.data_path=${DATASET_PATH}"     "++data.train.split_validation_size=0.0"     "++data.validation=null"     "++data.default.dataset_name=ResponseDataset"     "++data.default.input_key=input"     "++data.default.output_key=output"     "++data.default.processor=math_hf_data_processor"     "++data.default.env_name=math"     "++data.default.prompt_file=examples/prompts/cot.txt"     "++logger.log_dir=${logroot}"     "++checkpointing.enabled=true"     "++checkpointing.save_period=${SAVE_PERIOD}"     "++checkpointing.keep_top_k=6"     "++checkpointing.checkpoint_dir=${resroot}"     2>&1 | tee "$run_log"

  local rc=${PIPESTATUS[0]}
  echo "$(date '+%F %T %Z') seed=${SEED} arm=${arm} rc=${rc} run_log=${run_log}" | tee -a "$STATUS"
  return "$rc"
}

case "$MODE" in
  train)
    run_arm train "$TRAIN_LR"
    ;;
  frozen)
    run_arm frozen "$FROZEN_LR"
    ;;
  both)
    run_arm train "$TRAIN_LR"
    run_arm frozen "$FROZEN_LR"
    ;;
esac

echo "$(date '+%F %T %Z') DONE mode=${MODE} seed=${SEED} exp_root=${EXP_ROOT}" | tee -a "$STATUS"
