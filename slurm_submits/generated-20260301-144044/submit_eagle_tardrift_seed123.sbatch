TARGET_MODEL="/home/scratch.shaunakj_other/.cache/huggingface/hub/models--Qwen--Qwen3-32B/snapshots/9216db5781bf21249d130ec9da846c4624c16137"
EAGLE_MODEL="/home/scratch.shaunakj_other/.cache/hf_user/hub/models--RedHatAI--Qwen3-32B-speculator.eagle3/snapshots/e5756763c9b3bef3cc260cab70b76008fb42a81b"
