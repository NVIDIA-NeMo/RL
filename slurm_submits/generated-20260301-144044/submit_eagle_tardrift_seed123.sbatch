mkdir -p "$SCR/t" "$SCR/logs" "$SCR/results"   "$UV_CACHE_DIR" "$XDG_CACHE_HOME" "$VLLM_CACHE_ROOT"   "$HF_HUB_CACHE" "$HF_DATASETS_CACHE" "$RAY_TMPDIR"

if ! .venv/bin/python -c "import torch, vllm" >/dev/null 2>&1; then
  echo "ERROR: vLLM import failed in frozen env (.venv), likely dependency/ABI mismatch." | tee -a "$SCR/logs/eagle_tardrift_preflight.err"
