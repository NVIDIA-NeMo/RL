# First we start the head of the ray cluster on one of the physical nodes.
# Give the head node actual resources to make it schedulable.
# Pyxis/Enroot containers do not inherit the submit host's environment,
# so BAKED_ENV is prepended to give the script the variables it needs.
HEAD_BODY=$(cat <<'HEAD_BODY_EOF'
set -oux pipefail

env

exit-dramatically() {
    # Use SIGTERM to forcefully terminate the srun process
    pkill -P $$ || true
    kill -TERM 0 || true
    # As a last resort, exit with a non-zero code
    exit 1
}
export -f exit-dramatically

# Background process to check for ENDED file
monitor-sidecar() {
  set +x
  while true; do
    sleep 60
    if [[ -f "$LOG_DIR/ENDED" ]]; then
      echo "Detected ENDED file, terminating..."
      exit-dramatically
    fi
  done
}
monitor-sidecar &

# Background process to sync ray logs every $RAY_LOG_SYNC_FREQUENCY seconds
log-sync-sidecar() {
  set +x
  if [[ -z "$RAY_LOG_SYNC_FREQUENCY" ]]; then
    echo "RAY_LOG_SYNC_FREQUENCY is not set, skipping log sync sidecar"
    return
  fi
  mkdir -p "$LOG_DIR/ray"
  while true; do
    sleep "$RAY_LOG_SYNC_FREQUENCY"
    if ls /tmp/ray/session_[0-9]* > /dev/null 2>&1; then
      for session_dir in /tmp/ray/session_[0-9]*/; do
        if [[ -d "$session_dir/logs" ]]; then
          session_name=$(basename "$session_dir")
          mkdir -p "$LOG_DIR/ray/$session_name"
          if command -v rsync > /dev/null 2>&1; then
            rsync -ahP "$session_dir/logs/" "$LOG_DIR/ray/$session_name/logs/" 2>/dev/null || true
          else
            cp -r "$session_dir/logs" "$LOG_DIR/ray/$session_name/"
          fi
        fi
      done
    fi
    if [[ -f "$LOG_DIR/ENDED" ]]; then
      echo "Log sync sidecar terminating..."
      break
    fi
  done
}
log-sync-sidecar &

# Background process to periodically write the current worker_units count to a file
# on the shared filesystem. The submit host reads this file instead of issuing srun RPCs.
# Uses atomic write-to-tmp + mv to avoid partial reads.
ray-status-sidecar() {
  set +x
  while true; do
    sleep 10
    units=$(ray status 2>/dev/null | grep "worker_units" | awk -F'[/. ]' '{print $4}' || echo 0)
    echo "$units" > "$LOG_DIR/.ray_worker_units.tmp"
    mv "$LOG_DIR/.ray_worker_units.tmp" "$LOG_DIR/ray_worker_units"
    if [[ -f "$LOG_DIR/ENDED" ]]; then break; fi
  done
}
ray-status-sidecar &

# Sync locally-compiled caches back to Lustre so subsequent jobs start warm.
# Content-addressed: --ignore-existing is safe (identical hashes = identical files).
# Uses trap EXIT instead of ENDED polling — ENDED only fires on failure, but we also
# need to sync on successful completion (Slurm SIGTERM → container exit).
#
# vLLM compile caches are delayed by NRL_CACHE_SYNC_DELAY_SECONDS (default 2700) from job start.
# torch.compile runs during engine init at job startup
# by the time the delay elapses, assume all vLLM instances have finished compiling. 
# Syncing earlier risks pushing partially-compiled caches to Lustre that seed from them.
cache-sync-sidecar() {
  set +x
  # note: ansubramania - cache writeback disabled unconditionally
  # every node rsync'ing into the same cache_write/
  # subtree under --ignore-existing causes Lustre MDS lock build-up 
  # and invalidation storms at larger scales.
  return
  if [[ -z "${CACHE_SYNC_FREQUENCY:-}" ]] || [[ "${CACHE_SYNC_FREQUENCY}" == "0" ]]; then
    return
  fi

  _sync_one() {
    local src="$1" dst="$2" name="$3"
    [[ -z "$src" || -z "$dst" ]] && return
    [[ -d "$src" ]] || return
    [[ -n "$(ls -A "$src" 2>/dev/null)" ]] || return
    mkdir -p "$dst"
    local _err _rc=0
    _err=$(rsync -a --ignore-existing --exclude '.tmp_*' --exclude 'tmp*/' --prune-empty-dirs \
      "$src/" "$dst/" 2>&1) || _rc=$?
    if (( _rc == 0 || _rc == 23 || _rc == 24 )); then
      echo "[CACHE SYNC] ${name}: synced to Lustre"
    else
      echo "[CACHE SYNC] ${name}: sync failed (rc=${_rc}: ${_err})"
    fi
  }

  _sync_cache_rsync() {
    local src="$1" dst="$2" name="$3" force="${4:-0}"
    [[ -z "$src" || -z "$dst" ]] && return 1
    [[ -d "$src" ]] || return 1
    [[ -n "$(ls -A "$src" 2>/dev/null)" ]] || return 1

    if (( ! force )); then
      local now elapsed
      now=$(date +%s)
      elapsed=$(( now - ${NRL_JOB_START_EPOCH%%.*} ))
      if (( elapsed < NRL_CACHE_SYNC_DELAY_SECONDS )); then
        echo "[CACHE SYNC] ${name}: skipping (${elapsed}s since job start, waiting for ${NRL_CACHE_SYNC_DELAY_SECONDS}s)"
        return 1
      fi
      if find "$src" -type f -mmin -5 -print -quit 2>/dev/null | grep -q .; then
        echo "[CACHE SYNC] ${name}: skipping (files modified in last 5m)"
        return 1
      fi
    fi

    mkdir -p "$dst"
    local _err _rc=0
    _err=$(rsync -a --exclude='tmp*' --exclude='.tmp_*' "$src/" "$dst/" 2>&1) || _rc=$?
    if (( _rc == 0 || _rc == 23 || _rc == 24 )); then
      echo "[CACHE SYNC] ${name}: rsynced to Lustre ($(du -sh "$dst" 2>/dev/null | cut -f1))"
      return 0
    else
      echo "[CACHE SYNC] ${name}: rsync failed (rc=${_rc}: ${_err})"
      return 1
    fi
  }

  _sync_vllm_caches() {
    local base="${NRL_VLLM_LOCAL_CACHE_DIR:-}"
    local lustre_base="${LUSTRE_VLLM_CACHE:-}"
    [[ -z "$base" || -z "$lustre_base" ]] && return
    # Bare base dir: Gym's local_vllm_model and other non-NeMo-RL vLLM
    # processes inherit VLLM_CACHE_ROOT without a _seed suffix.
    [[ -d "$base" ]] && _sync_one "$base" "${lustre_base}" "vLLM_base"
    # Per-seed dirs: NeMo RL vllm_worker appends _{seed} to the base.
    for d in "${base}"_*; do
      [[ -d "$d" ]] || continue
      local suffix="${d#"${base}"}"
      _sync_one "$d" "${lustre_base}" "vLLM${suffix}"
    done
  }

  _vllm_synced=0
  _inductor_synced=0
  _triton_synced=0

  _sync_all() {
    if (( ! _vllm_synced )); then
      local _now _elapsed
      _now=$(date +%s)
      _elapsed=$(( _now - ${NRL_JOB_START_EPOCH%%.*} ))
      if (( _elapsed >= ${NRL_CACHE_SYNC_DELAY_SECONDS:-2700} )); then
        _sync_vllm_caches
        _vllm_synced=1
      else
        echo "[CACHE SYNC] vLLM: skipping (${_elapsed}s since job start, waiting for ${NRL_CACHE_SYNC_DELAY_SECONDS:-2700}s)"
      fi
    fi
    if (( ! _inductor_synced )); then
      _sync_cache_rsync "${INDUCTOR_CACHE_DIR:-}" "${CACHE_WRITE_DIR:+${CACHE_WRITE_DIR}/inductor_cache}" "Inductor" \
        && _inductor_synced=1
    fi
    if (( ! _triton_synced )); then
      _sync_cache_rsync "${TRITON_CACHE_DIR:-}" "${CACHE_WRITE_DIR:+${CACHE_WRITE_DIR}/triton_cache}" "Triton" \
        && _triton_synced=1
    fi
  }

  _sync_final() {
    local _nnodes=${TOTAL_NUM_NODES:-${SLURM_JOB_NUM_NODES:-1}}
    local _auto_exit_window=$(( _nnodes / 20 ))
    (( _auto_exit_window < 15 )) && _auto_exit_window=15
    (( _auto_exit_window > 45 )) && _auto_exit_window=45
    local _exit_window=${NRL_CACHE_SYNC_EXIT_JITTER_SECONDS:-$_auto_exit_window}
    local _exit_jitter=$(( RANDOM % _exit_window ))
    echo "[CACHE SYNC] Exit jitter: ${_exit_jitter}s (window=${_exit_window}s, nodes=${_nnodes})"
    sleep "$_exit_jitter"
    _sync_vllm_caches
    _sync_cache_rsync "${INDUCTOR_CACHE_DIR:-}" "${CACHE_WRITE_DIR:+${CACHE_WRITE_DIR}/inductor_cache}" "Inductor" 1
    _sync_cache_rsync "${TRITON_CACHE_DIR:-}" "${CACHE_WRITE_DIR:+${CACHE_WRITE_DIR}/triton_cache}" "Triton" 1
  }

  trap '_sync_final; echo "[CACHE SYNC] Final sync complete (exit trap)."' EXIT

  local _jitter=$(( RANDOM % ${NRL_CACHE_SYNC_JITTER_SECONDS:-120} ))
  echo "[CACHE SYNC] Per-node jitter: ${_jitter}s (spreading initial sync across ${NRL_CACHE_SYNC_JITTER_SECONDS:-120}s window)"
  sleep "$_jitter"

  while true; do
    sleep "${CACHE_SYNC_FREQUENCY}"
    _sync_all
  done
}
cache-sync-sidecar &

# Patch nsight.py before starting Ray head
sed -i 's/context\.py_executable = " "\.join(self\.nsight_cmd) + " python"/context.py_executable = " ".join(self.nsight_cmd) + f" {context.py_executable}"/g' /opt/nemo_rl_venv/lib64/python*/site-packages/ray/_private/runtime_env/nsight.py

source "$LOG_DIR/topology_probe.sh"

# Start Ray head without --block
# Without --block, ray start --head starts the daemon and returns 0 once the
# GCS is listening. This lets us touch STARTED_RAY_HEAD after the head is
# actually ready, so workers connect on the first try instead of retrying
# against a port that isn't listening yet.
count=0
while [[ $count -lt $HEAD_NUM_RETRIES ]]; do
  # Clean up stale Ray state before every attempt.  If a previous attempt
  # timed out, it leaves a session directory behind.  Without cleaning it,
  # the next `ray start --head` hits:
  #   AssertionError: Session name ... does not match persisted value ...
  ray stop || true
  rm -rf /tmp/ray/session_* || true

  if [[ -n "$SETUP_COMMAND_FILE" ]] && [[ -f "$SETUP_COMMAND_FILE" ]]; then
    echo "[INFO] Running setup command from $SETUP_COMMAND_FILE..."
    bash "$SETUP_COMMAND_FILE"
  fi
  # Two-level evaluation: heredoc expands $RAY_RESOURCES (with \") into text,
  # then bash re-parses it so \" inside double quotes becomes clean ".
  if cat <<EOFINNER | bash; then
ray start --head \
    --disable-usage-stats \
    --resources="$RAY_RESOURCES" \
    --node-ip-address="$HEAD_NODE_IP" \
    --port=${PORT} \
    --ray-client-server-port=${RAY_CLIENT_SERVER_PORT} \
    --dashboard-port=${DASHBOARD_PORT} \
    --dashboard-host="$HEAD_NODE_IP" \
    --include-dashboard=True \
    --min-worker-port=${MIN_WORKER_PORT} \
    --max-worker-port=${MAX_WORKER_PORT} \
    \
    --node-manager-port=$((${NODE_MANAGER_PORT} + 1)) \
    --object-manager-port=$((${OBJECT_MANAGER_PORT} + 1)) \
    --runtime-env-agent-port=$((${RUNTIME_ENV_AGENT_PORT} + 1)) \
    --dashboard-agent-grpc-port=$((${DASHBOARD_AGENT_GRPC_PORT} + 1)) \
    --dashboard-agent-listen-port=$((${DASHBOARD_AGENT_LISTEN_PORT} + 1)) \
    --metrics-export-port=$((${METRICS_EXPORT_PORT} + 1)) \
    $RAY_DEBUGGER_ARGS
EOFINNER
    echo "[INFO] Ray head started successfully (attempt $((count+1))/$HEAD_NUM_RETRIES)"
    break
  fi
  count=$((count+1))
  echo "[WARN] Head node failed $count/$HEAD_NUM_RETRIES times, restarting in 5 seconds..."
  sleep 5
done
if [[ $count -ge $HEAD_NUM_RETRIES ]]; then
  touch "$LOG_DIR/ENDED"
  exit 1
fi

# Signal workers and submit host: Ray head GCS is now listening on $IP_HEAD.
# Workers poll for this file before attempting ray start --address.
touch "$LOG_DIR/STARTED_RAY_HEAD"

if [[ -n "$DRIVER_COMMAND_FILE" ]]; then
  # ── Non-interactive: poll for workers, then run the driver command ──
  RAY_STATUS_DEADLINE=$((SECONDS + 1800))
  while true; do
    worker_units=$(ray status 2>/dev/null | grep "worker_units" | awk -F'[/. ]' '{print $4}' || echo 0)
    echo "[INFO] Number of actors online: $worker_units/$NUM_ACTORS"
    if [[ "$worker_units" -eq "$NUM_ACTORS" ]]; then
      break
    fi
    if (( SECONDS > RAY_STATUS_DEADLINE )); then
      echo "[ERROR] Timed out waiting for all workers to connect ($worker_units/$NUM_ACTORS after 30 min)"
      touch "$LOG_DIR/ENDED"
      exit 1
    fi
    sleep 5
  done

  echo "All workers connected!"

  # Wait for all sandbox instances to be ready (if sandbox is configured).
  # Each sandbox task touches SANDBOX_READY_<hostname> after its port is listening.
  if [[ -n "$SANDBOX_PORTS_DIR" ]]; then
    echo "[INFO] Waiting for sandbox to be ready on all $TOTAL_NUM_NODES nodes..."
    SANDBOX_DEADLINE=$((SECONDS + 600))
    while true; do
      ready_count=$(ls -1 "$SANDBOX_PORTS_DIR"/SANDBOX_READY_* 2>/dev/null | wc -l)
      if [[ "$ready_count" -ge "$TOTAL_NUM_NODES" ]]; then
        break
      fi
      echo "[INFO] Sandbox ready on $ready_count/$TOTAL_NUM_NODES nodes..."
      if (( SECONDS > SANDBOX_DEADLINE )); then
        echo "[ERROR] Timed out waiting for sandbox ($ready_count/$TOTAL_NUM_NODES after 10 min)"
        touch "$LOG_DIR/ENDED"
        exit 1
      fi
      sleep 5
    done
    echo "[INFO] All $TOTAL_NUM_NODES sandbox instances ready."
  fi

  export NRL_RAY_READY_EPOCH=$(date +%s.%N)

  set +e
  bash "$DRIVER_COMMAND_FILE" > "$LOG_DIR/ray-driver.log" 2>&1
  exit_code=$?
  set -e
  exit $exit_code
else
  # ── Interactive: keep the container alive for user attachment ──
  # The user attaches via a separate srun --overlap (the attach script).
  # sleep infinity is invisible to the attached session.
  sleep infinity
fi
HEAD_BODY_EOF
)

