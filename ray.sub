      else
        echo "[CACHE SYNC] vLLM: skipping (${_elapsed}s since job start, waiting for ${NRL_CACHE_SYNC_DELAY_SECONDS:-2700}s)"
      fi
    fi
    if (( ! _inductor_synced )); then
      _sync_cache_rsync "${INDUCTOR_CACHE_DIR:-}" "${CACHE_WRITE_DIR:+${CACHE_WRITE_DIR}/inductor_cache}" "Inductor" \
        && _inductor_synced=1
    fi
    if (( ! _triton_synced )); then
      _sync_cache_rsync "${TRITON_CACHE_DIR:-}" "${CACHE_WRITE_DIR:+${CACHE_WRITE_DIR}/triton_cache}" "Triton" \
        && _triton_synced=1
    fi
  }

  _sync_final() {
    local _nnodes=${TOTAL_NUM_NODES:-${SLURM_JOB_NUM_NODES:-1}}
    local _auto_exit_window=$(( _nnodes / 20 ))
    (( _auto_exit_window < 15 )) && _auto_exit_window=15
    (( _auto_exit_window > 45 )) && _auto_exit_window=45
    local _exit_window=${NRL_CACHE_SYNC_EXIT_JITTER_SECONDS:-$_auto_exit_window}
    local _exit_jitter=$(( RANDOM % _exit_window ))
    echo "[CACHE SYNC] Exit jitter: ${_exit_jitter}s (window=${_exit_window}s, nodes=${_nnodes})"
    sleep "$_exit_jitter"
    _sync_vllm_caches
    _sync_cache_rsync "${INDUCTOR_CACHE_DIR:-}" "${CACHE_WRITE_DIR:+${CACHE_WRITE_DIR}/inductor_cache}" "Inductor" 1
    _sync_cache_rsync "${TRITON_CACHE_DIR:-}" "${CACHE_WRITE_DIR:+${CACHE_WRITE_DIR}/triton_cache}" "Triton" 1
  }

  trap '_sync_final; echo "[CACHE SYNC] Final sync complete (exit trap)."' EXIT

  local _jitter=$(( RANDOM % ${NRL_CACHE_SYNC_JITTER_SECONDS:-120} ))
  echo "[CACHE SYNC] Per-node jitter: ${_jitter}s (spreading initial sync across ${NRL_CACHE_SYNC_JITTER_SECONDS:-120}s window)"
  sleep "$_jitter"

  while true; do
    sleep "${CACHE_SYNC_FREQUENCY}"
    _sync_all
  done
}
cache-sync-sidecar &

# Patch nsight.py before starting Ray worker
sed -i 's/context\.py_executable = " "\.join(self\.nsight_cmd) + " python"/context.py_executable = " ".join(self.nsight_cmd) + f" {context.py_executable}"/g' /opt/nemo_rl_venv/lib64/python*/site-packages/ray/_private/runtime_env/nsight.py

source "$LOG_DIR/topology_probe.sh"

# Run SETUP_COMMAND early so node-local work (cache seeding, env prep)
# overlaps with head startup instead of blocking on it sequentially.
# Current launch scripts use this exclusively for Lustre→/tmp rsync
# which is pure I/O and has no dependency on Ray being up.
if [[ -n "$SETUP_COMMAND_FILE" ]] && [[ -f "$SETUP_COMMAND_FILE" ]]; then
  echo "[INFO] Worker $SLURM_PROCID: running setup command (parallel with head startup)..."
  bash "$SETUP_COMMAND_FILE"
  echo "[INFO] Worker $SLURM_PROCID: setup command finished."
fi

echo "[INFO] Worker $SLURM_PROCID: waiting for Ray head GCS to be ready..."
while true; do
  if [[ -f "$LOG_DIR/STARTED_RAY_HEAD" ]]; then
    echo "[INFO] Worker $SLURM_PROCID: Ray head GCS is ready, connecting."
    break
  fi
  if [[ -f "$LOG_DIR/ENDED" ]]; then
    echo "[ERROR] ENDED detected before head started, exiting."
    exit 1
  fi
  sleep 2
done

# Stagger worker connections to avoid thundering-herd on the GCS server.
# All workers detect STARTED_RAY_HEAD within the same ~2s polling window;
# without jitter they all issue `ray start --address` simultaneously.
# Target ~100 workers/sec connection rate
_jitter_window=$(( TOTAL_NUM_NODES / 100 ))
(( _jitter_window < 2 )) && _jitter_window=2
_jitter=$(( RANDOM % _jitter_window ))
echo "[INFO] Worker $SLURM_PROCID: sleeping ${_jitter}s (jitter window ${_jitter_window}s) before connecting"
sleep "$_jitter"

count=0
while [[ $count -lt $WORKER_NUM_RETRIES ]]; do
  # Clean up stale Ray state before every attempt so a half-started
  # raylet from a previous attempt doesn't block the next one.
  ray stop || true
  rm -rf /tmp/ray/session_* || true

  # Two-level evaluation: heredoc expands $RAY_RESOURCES (with \") into text,
  # then bash re-parses it so \" inside double quotes becomes clean ".
  echo "[INFO] Worker $SLURM_PROCID: starting Ray worker (attempt $((count+1))/$WORKER_NUM_RETRIES)..."
  cat <<EOFINNER | bash
ray start --address "$IP_HEAD" \
          --disable-usage-stats \
          --resources="$RAY_RESOURCES" \
          --min-worker-port=${MIN_WORKER_PORT} \
          --max-worker-port=${MAX_WORKER_PORT} \
          \
          --node-manager-port=${NODE_MANAGER_PORT} \
          --object-manager-port=${OBJECT_MANAGER_PORT} \
          --runtime-env-agent-port=${RUNTIME_ENV_AGENT_PORT} \
          --dashboard-agent-grpc-port=${DASHBOARD_AGENT_GRPC_PORT} \
          --dashboard-agent-listen-port=${DASHBOARD_AGENT_LISTEN_PORT} \
          --metrics-export-port=${METRICS_EXPORT_PORT} \
          $RAY_DEBUGGER_ARGS \
          \
          --block
EOFINNER
  count=$((count+1))
  _retry_jitter=$(( 5 + RANDOM % 10 ))
  echo "[WARN] Worker $SLURM_PROCID failed $count/$WORKER_NUM_RETRIES times, restarting in ${_retry_jitter}s..."
  sleep "$_retry_jitter"
done
touch "$LOG_DIR/ENDED"
exit 1
WORKER_BODY_EOF
)

# Join BAKED_ENV + body into complete scripts passed to srun via bash -c.
# The single-quoted heredoc bodies contain unexpanded $vars that resolve at
# container runtime; BAKED_ENV provides the submit-host values they need.
HEAD_SCRIPT=$(printf '%s\n%s' "$BAKED_ENV" "$HEAD_BODY")
WORKER_SCRIPT=$(printf '%s\n%s' "$BAKED_ENV" "$WORKER_BODY")

[[ -z "$HEAD_SCRIPT" ]] && echo "[FATAL] HEAD_SCRIPT is empty" >&2 && exit 1
[[ -z "$WORKER_SCRIPT" ]] && echo "[FATAL] WORKER_SCRIPT is empty" >&2 && exit 1

bash -n <(printf '%s' "$HEAD_SCRIPT") || { echo "[FATAL] Head script has syntax errors" >&2; exit 1; }
bash -n <(printf '%s' "$WORKER_SCRIPT") || { echo "[FATAL] Worker script has syntax errors" >&2; exit 1; }

########################################################
# Run sandbox in parallel on all nodes (overlap).
# Each per-node task polls its own localhost port and writes a per-node
# signal file so the head container can gate on all instances being ready.
########################################################
SANDBOX_PORT="${NEMO_SKILLS_SANDBOX_PORT:-6000}"
SANDBOX_BASE_PORT="${SANDBOX_BASE_PORT:-6001}"
if [[ -n "${SANDBOX_CONTAINER:-}" ]] && [[ -n "${SANDBOX_COMMAND:-}" ]]; then
  echo "[INFO] Starting sandbox on all $SLURM_JOB_NUM_NODES nodes (ports_dir=$SANDBOX_PORTS_DIR, port=$SANDBOX_PORT, base_port=$SANDBOX_BASE_PORT)..."
  srun --output "$SANDBOX_PORTS_DIR/sandbox-%t.log" \
    --container-image="$SANDBOX_CONTAINER" \
    --container-mounts="$SANDBOX_PORTS_DIR:$SANDBOX_PORTS_DIR${SHARED_TEMP_DIR:+,$SHARED_TEMP_DIR:$SHARED_TEMP_DIR}" \
    --no-container-mount-home \
    --mpi=pmix \
    -A "$SLURM_JOB_ACCOUNT" \
    -p "$SLURM_JOB_PARTITION" \
    --wait=60 \
    --kill-on-bad-exit=1 \
    --overlap \
    --nodes="$SLURM_JOB_NUM_NODES" \
    --ntasks-per-node=1 \
    --export=ALL,SANDBOX_PORTS_DIR=$SANDBOX_PORTS_DIR,SANDBOX_WORKER_BASE_PORT=$SANDBOX_BASE_PORT,NGINX_PORT=$SANDBOX_PORT \
    bash -xc '
      ('"$SANDBOX_COMMAND"') &
      SANDBOX_PID=$!
      deadline=$((SECONDS + 300))
      while ! (echo > /dev/tcp/localhost/'"$SANDBOX_PORT"') 2>/dev/null; do
        if ! kill -0 $SANDBOX_PID 2>/dev/null; then
          echo "[ERROR] Sandbox process died before becoming ready on $(hostname)"
          exit 1
        fi
        if (( SECONDS > deadline )); then
          echo "[ERROR] Sandbox not ready on $(hostname) after 5 min"
          exit 1
        fi
        sleep 2
      done
      touch '"$SANDBOX_PORTS_DIR"'/SANDBOX_READY_$(hostname)
      echo "[INFO] Sandbox ready on $(hostname):'"$SANDBOX_PORT"'"
      wait $SANDBOX_PID
    ' &
  SRUN_PIDS["sandbox"]=$!
  echo "[INFO] Sandbox started in background (PID: ${SRUN_PIDS["sandbox"]})"
else
  echo "[INFO] SANDBOX_CONTAINER or SANDBOX_COMMAND not defined, skipping sandbox startup"
fi

# Start head node
srun $COMMON_SRUN_ARGS --container-name=ray-head --nodes=1 --ntasks=1 --cpus-per-task=$CPUS_PER_WORKER -w "$head_node" -o $LOG_DIR/ray-head.log bash -x -c "$HEAD_SCRIPT" &
SRUN_PIDS["ray-head"]=$!

# Start worker nodes (all nodes except the head).
# In single-node mode (_num_workers=0), the head is the only compute node
# and already registers its GPUs as Ray resources, so no workers are needed.
_num_workers=$((SLURM_JOB_NUM_NODES - 1))
if [[ $_num_workers -gt 0 ]]; then
  # srun -o with %t produces per-task log files
  # Zero-pad to the width of the worker count so filenames sort naturally
  _task_digits=${#_num_workers}
  srun $COMMON_SRUN_ARGS --container-name=ray-worker --exact \
    --nodes=$_num_workers \
    --ntasks=$_num_workers \
    --ntasks-per-node=1 \
    --cpus-per-task=$CPUS_PER_WORKER \
    --kill-on-bad-exit=0 \
    --exclude="$head_node" \
    -o "$LOG_DIR/ray-worker-%0${_task_digits}t.log" \
    bash -xc "$WORKER_SCRIPT" &
  SRUN_PIDS["ray-workers"]=$!
else
  echo "[INFO] Single-node mode: head node is the only compute node, no workers to launch"
fi

# Wait for the Ray head GCS to be ready
# signal file is touched after ray start --head succeeds
while check_srun_processes && ! test -f "$LOG_DIR/STARTED_RAY_HEAD"; do
  echo "[INFO][$(date)] Waiting for Ray head GCS to be ready..."
  sleep 2
done

if [[ -n "$COMMAND" ]]; then
  # Non-interactive: head container handles polling + command execution
  # The head srun exits when the command finishes (or on failure).
  set +e
  wait ${SRUN_PIDS["ray-head"]}
  exit_code=$?
  set -e
  exit $exit_code
else
  # Interactive: poll for workers from submit host, then idle
  RAY_STATUS_DEADLINE=$((SECONDS + 1800))
  while true; do
    worker_units=$(cat "$LOG_DIR/ray_worker_units" 2>/dev/null || echo -1)
    echo "[INFO] Number of actors online: $worker_units/$NUM_ACTORS"
    if [[ "$worker_units" -eq "$NUM_ACTORS" ]]; then
      break
    fi
    check_srun_processes
    if (( SECONDS > RAY_STATUS_DEADLINE )); then
      echo "[ERROR] Timed out waiting for all workers to connect ($worker_units/$NUM_ACTORS after 30 min)"
      touch "$LOG_DIR/ENDED"
      exit 1
    fi
    sleep 5
  done

  echo "All workers connected!"

  CONTAINER_CWD=$(scontrol show job $SLURM_JOB_ID | grep -oP 'WorkDir=\K[^ ]+' | head -1)
  echo "[INFO]: Ray Cluster is idled, run this on the slurm head node to get a shell to the head node:"
  cat <<EOF >$SLURM_SUBMIT_DIR/${SLURM_JOB_ID}-attach.sh
# No args launches on the head node (node 0)
# Args 1-N launch on worker nodes (nodes 1 through N-1)
# Optional: set COMMAND='...' to run non-interactively instead of opening an interactive shell
WORKER_NUM=\${1:-}
if [[ -z "\$WORKER_NUM" ]]; then
  if [[ -n "\${COMMAND:-}" ]]; then
    srun --no-container-mount-home $GRES_ARG -A $SLURM_JOB_ACCOUNT -p $SLURM_JOB_PARTITION --overlap --container-name=ray-head --container-workdir=$CONTAINER_CWD --nodes=1 --ntasks=1 -w "$head_node" --jobid $SLURM_JOB_ID bash -c "\$COMMAND"
  else
    srun --no-container-mount-home $GRES_ARG -A $SLURM_JOB_ACCOUNT -p $SLURM_JOB_PARTITION --overlap --container-name=ray-head --container-workdir=$CONTAINER_CWD --nodes=1 --ntasks=1 -w "$head_node" --jobid $SLURM_JOB_ID --pty bash
  fi
elif [[ $SLURM_JOB_NUM_NODES -eq 1 ]]; then
  echo "Error: Single-node mode — only the head node is available. Run without arguments."
  exit 1
else
  if [[ \$WORKER_NUM -lt 1 || \$WORKER_NUM -ge $SLURM_JOB_NUM_NODES ]]; then
    echo "Error: WORKER_NUM must be between 1 and $((SLURM_JOB_NUM_NODES-1))"
    exit 1
  fi
  nodes_array=($nodes)
  node="\${nodes_array[\$WORKER_NUM]}"
  if [[ -n "\${COMMAND:-}" ]]; then
    srun --no-container-mount-home $GRES_ARG -A $SLURM_JOB_ACCOUNT -p $SLURM_JOB_PARTITION --overlap --container-name=ray-worker --container-workdir=$CONTAINER_CWD --nodes=1 --ntasks=1 -w "\$node" --jobid $SLURM_JOB_ID bash -c "\$COMMAND"
  else
    srun --no-container-mount-home $GRES_ARG -A $SLURM_JOB_ACCOUNT -p $SLURM_JOB_PARTITION --overlap --container-name=ray-worker --container-workdir=$CONTAINER_CWD --nodes=1 --ntasks=1 -w "\$node" --jobid $SLURM_JOB_ID --pty bash
  fi
fi
EOF
  chmod +x $SLURM_SUBMIT_DIR/${SLURM_JOB_ID}-attach.sh
  echo "     COMMAND='echo hello' bash $SLURM_SUBMIT_DIR/${SLURM_JOB_ID}-attach.sh    # run a non-interactive command on head node"
  echo "     bash $SLURM_SUBMIT_DIR/${SLURM_JOB_ID}-attach.sh    # to attach to head node (i.e., 'worker 0')"
  if [[ $SLURM_JOB_NUM_NODES -gt 1 ]]; then
    echo "     bash $SLURM_SUBMIT_DIR/${SLURM_JOB_ID}-attach.sh 1  # to attach to worker 1"
    echo "     bash $SLURM_SUBMIT_DIR/${SLURM_JOB_ID}-attach.sh 2  # to attach to worker 2, etc."
  fi
  sleep infinity
fi

