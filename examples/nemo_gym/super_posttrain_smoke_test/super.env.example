# Copy to super.env and fill in site/user-specific values before launching.

export EXP_NAME=stage1.1-rlvr1-14node-pp4
export CONFIG_PATH="${PWD}/examples/nemo_gym/super_posttrain_smoke_test/configs/small_stage1_rlvr_14node.yaml"
export MODEL_PATH="/path/to/hf/checkpoint"
export TRAIN_PATH="${PWD}/examples/nemo_gym/super_posttrain_smoke_test/data/rlvr1/train-split.jsonl"
export VAL_PATH="${PWD}/examples/nemo_gym/super_posttrain_smoke_test/data/rlvr1/val-split.jsonl"

export PERSISTENT_CACHE="${PWD}/examples/nemo_gym/super_posttrain_smoke_test/cache"
export CONTAINER="/path/to/nemo-rl.squashfs"
export SANDBOX_CONTAINER="/path/to/nemo-skills-sandbox.sqsh"
export SLURM_PARTITION="batch"
export SLURM_ACCOUNT="account"
export SBATCH_NUM_NODES=14
export SLURM_TIME_LIMIT=2:0:0

export WANDB_PROJ="super-v3-posttraining"
export WANDB_API_KEY=""
export HF_TOKEN=""

export GYM_VENV_DIR="${PERSISTENT_CACHE}/gym_venvs"
export NEMO_RL_VENV_DIR="${PERSISTENT_CACHE}/ray_venvs"
export UV_CACHE_DIR_OVERRIDE="${PERSISTENT_CACHE}/uv_cache"
export NRL_FORCE_REBUILD_VENVS=false
export DRY_RUN=true
